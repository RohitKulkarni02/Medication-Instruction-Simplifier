# Copy to `.env` and fill in locally. Never commit `.env` or paste real values into chats/docs.
#
# If any key was shared publicly, revoke it in the provider dashboard and create a new key.

# Optional — higher openFDA rate limits
OPENFDA_API_KEY=

# Label simplification — Groq (https://console.groq.com/)
GROQ_API_KEY=
# Optional overrides
# GROQ_SIMPLIFY_MODEL=llama3-70b-8192

# Label simplification — OpenAI (optional)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
